# 授权服务器配置
PORT=3000

# --- 邮件发送配置 (SMTP 模式) ---
# 如果你使用 QQ 邮箱，Host 填 smtp.qq.com，Port 填 465，Secure 填 true
# 如果你使用网易邮箱，Host 填 smtp.163.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=你的密钥或授权码

# 发件人显示名称和地址
FROM_EMAIL=输入法锁定团队 <noreply@yourdomain.com>

# 每年允许换机次数
MAX_DEVICE_CHANGES_PER_YEAR=2
