# 授权服务器配置
PORT=3000

# --- 邮件发送配置 (SMTP 模式) ---
# 推荐使用阿里云邮件推送（国内用户收件率最高）：
#   SMTP_HOST=smtpdm.aliyun.com  SMTP_PORT=465  SMTP_SECURE=true
#   SMTP_USER=noreply@mail.你的域名（在阿里云"发信地址"中创建）
#   SMTP_PASS=在阿里云"发信地址"→"设置SMTP密码"中获取
#
# 如果你使用 QQ 邮箱：Host=smtp.qq.com, Port=465, Secure=true, User=QQ号@qq.com, Pass=授权码
# 如果你使用网易邮箱：Host=smtp.163.com
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@mail.你的域名
SMTP_PASS=阿里云SMTP密码

# 发件人显示名称和地址（格式：显示名称 <邮件地址>）
FROM_EMAIL=输入法锁定 <noreply@mail.你的域名>

# 每年允许换机次数
MAX_DEVICE_CHANGES_PER_YEAR=2
